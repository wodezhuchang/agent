[project]
requires = ["python-3.12"]
project_type = ""

[preview]
preview_enable = "enabled"

[dev]
build = ["bash", "projects/scripts/coze-preview-build.sh"]
run = ["bash", "projects/scripts/coze-preview-run.sh"]

[deploy.profile]
kind = "service"
flavor = "agent"

[deploy]
build = ["bash", "projects/scripts/coze-deploy-build.sh"]
run = ["bash", "projects/scripts/coze-deploy-run.sh"]

[subprojects]
path = ["projects"]
